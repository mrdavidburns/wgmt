---
layout: layouts/base.njk
title: Service Areas — Philadelphia, Main Line, Delaware, Chester, Montgomery & Bucks Counties
description: Countertop fabrication and installation across Greater Philadelphia — the Main Line, Delaware County, Chester County, Montgomery County, Bucks County, and the city itself.
permalink: /service-areas/
---

<div class="page-head page-head--split">
  <div>
    <span class="kicker">Service Areas</span>
    <h1>{{ serviceAreas.intro.heading }}</h1>
  </div>
  <p class="lede lede--sm" style="max-width:44ch">{{ serviceAreas.intro.lede }}</p>
</div>

<div class="section">
  <div class="grid grid--3" style="gap:40px">
    {% for a in serviceAreas.regions %}
      <div class="value">
        <h3>{{ a.name }}</h3>
        <p>{{ a.blurb }}</p>
        <p style="font-size:13px;color:var(--muted);margin-top:8px">{{ a.towns }}</p>
      </div>
    {% endfor %}
  </div>
</div>

<div class="section" style="padding-bottom:0">
  <div class="section-head">
    <h2>{{ serviceAreas.mapHeading }}</h2>
    <p class="lede lede--sm" style="max-width:44ch">{{ site.showroom.address1 }}, {{ site.showroom.address2 }} · {{ site.showroom.hours1 }} · {{ site.showroom.hours2 }} · <a href="{{ site.showroom.mapsUrl }}" target="_blank" rel="noopener">Get directions</a></p>
  </div>
</div>
<div class="embed-frame embed-frame--map">
  <iframe src="https://www.google.com/maps?q=Wholesale+Granite+Marble+%26+Tile,+{{ site.showroom.address1 | urlencode }},+{{ site.showroom.address2 | urlencode }}&output=embed" title="Map to the WGMT showroom at {{ site.showroom.address1 }}, {{ site.showroom.address2 }}" loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
</div>

<div class="section">
  <h2 style="margin-bottom:36px">{{ serviceAreas.faqHeading }}</h2>
  <div class="grid grid--3" style="gap:40px">
    {% for f in faq %}
      <div class="value">
        <h3 style="font-size:16px">{{ f.q }}</h3>
        <p>{{ f.a }}</p>
      </div>
    {% endfor %}
  </div>
</div>

{% set cta = { text: serviceAreas.cta.text, button: serviceAreas.cta.button } %}
{% include "partials/cross-cta.njk" %}

---
layout: layouts/base.njk
title: Granite, Quartz, Marble & Tile in Ardmore, PA
description: Granite, quartz, marble, and tile — fabricated in-house on the Main Line since 2001, installed with a lifetime warranty, at wholesale pricing.
---

<div class="hero">
  <div class="hero__copy">
    <span class="kicker">Ardmore · Since {{ site.since }}</span>
    <h1>{{ home.hero.heading }}</h1>
    <p class="lede">{{ home.hero.lede }}</p>
    <div class="hero__actions">
      <a class="btn btn--dark" href="/contact/">{{ home.hero.primaryButton }}</a>
      <a class="btn btn--link" href="/contact/">{{ home.hero.secondaryButton }}</a>
    </div>
  </div>
  <div class="hero__media">
    <img src="{{ home.hero.image }}" alt="{{ home.hero.alt }}" fetchpriority="high">
    <div class="hero__caption">{{ home.hero.caption }}</div>
  </div>
</div>

<div class="section">
  <div class="section-head">
    <h2>{{ home.materialsHeading }}</h2>
    <a class="text-link" href="/countertops/">Browse all stone →</a>
  </div>
  <div class="grid grid--4">
    {% for m in materials %}
      <a class="card" href="{{ m.url }}">
        <div class="photo photo--tall"><img src="{{ m.image }}" alt="{{ m.alt }}" loading="lazy"></div>
        <span class="card__title">{{ m.name }}</span>
        <span class="card__meta">{{ m.desc }}</span>
      </a>
    {% endfor %}
  </div>
</div>

<div class="band band--split">
  <div class="band__cell">
    <span class="kicker kicker--light">{{ home.band.kicker }}</span>
    <p class="band__quote">&ldquo;{{ home.band.quote }}&rdquo;</p>
    <span class="band__attr">{{ home.band.attribution }}</span>
  </div>
  <div class="band__cell band__cell--divided">
    <h3>{{ home.band.heading }}</h3>
    <p class="band__note">{{ home.band.note }}</p>
    <a class="btn btn--light" href="/contact/" style="align-self:flex-start">{{ home.band.button }}</a>
  </div>
</div>

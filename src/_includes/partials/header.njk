<header class="header">
  <a class="header__brand" href="/">
    <img src="/assets/img/logo-180.png" alt="" width="54" height="54">
    <span class="header__wordmark">{{ site.name }}</span>
  </a>

  <button class="header__toggle" aria-expanded="false" aria-controls="site-nav" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>

  <nav class="header__nav" id="site-nav">
    {% for item in nav %}
      {% if item.children %}
        <div class="nav-sub">
          <a href="{{ item.url }}" {% if page.url == item.url or page.url.startsWith(item.url) %}aria-current="page"{% endif %} aria-haspopup="true">{{ item.label }}<span class="nav-sub__caret" aria-hidden="true">▾</span></a>
          <div class="nav-sub__menu">
            {% for child in item.children %}
              <a href="{{ child.url }}" {% if page.url == child.url %}aria-current="page"{% endif %}>{{ child.label }}</a>
            {% endfor %}
          </div>
        </div>
      {% else %}
        <a href="{{ item.url }}" {% if page.url == item.url %}aria-current="page"{% endif %}>{{ item.label }}</a>
      {% endif %}
    {% endfor %}
    <a class="header__cta" href="/contact/" {% if page.url == "/contact/" %}aria-current="page"{% endif %}>Visit the Showroom</a>
  </nav>
</header>

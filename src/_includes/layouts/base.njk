<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} · {% endif %}{{ site.name }}</title>
  <meta name="description" content="{{ description or site.tagline }}">
  {%- if noindex %}
  <meta name="robots" content="noindex, follow">
  {%- else %}
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  {%- endif %}
  <meta property="og:title" content="{% if title %}{{ title }} · {% endif %}{{ site.name }}">
  <meta property="og:description" content="{{ description or site.tagline }}">
  <meta property="og:image" content="{{ site.url }}/assets/img/og-image.jpg">
  <meta property="og:image:alt" content="Kitchen with stone countertops by {{ site.name }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:locale" content="en_US">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{% if title %}{{ title }} · {% endif %}{{ site.name }}">
  <meta name="twitter:description" content="{{ description or site.tagline }}">
  <meta name="twitter:image" content="{{ site.url }}/assets/img/og-image.jpg">
  <meta name="geo.region" content="US-PA">
  <meta name="geo.placename" content="Ardmore">
  <meta name="ICBM" content="40.0052017, -75.2860477">
  {% include "partials/schema.njk" %}
  <link rel="icon" href="/assets/img/logo-180.png">
  <link rel="apple-touch-icon" href="/assets/img/logo-180.png">
  <link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>

  <a class="skip-link" href="#page">Skip to content</a>

  {% include "partials/topbar.njk" %}
  {% include "partials/header.njk" %}

  <main id="page">
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}

  <script src="/assets/js/main.js" defer></script>
</body>
</html>

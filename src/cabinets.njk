---
layout: layouts/base.njk
title: Kitchen Cabinets — Ardmore & the Main Line
description: Cabinets designed in 3D and coordinated with your counters and tile — one shop, one crew, one install date, anywhere in Greater Philadelphia.
permalink: /cabinets/
---

<div class="hero hero--short">
  <div class="hero__copy">
    <span class="kicker">Cabinetry</span>
    <h1>{{ cabinets.hero.heading }}</h1>
    <p class="lede" style="font-size:16px">{{ cabinets.hero.lede }}</p>
    <div class="hero__actions">
      <a class="btn btn--dark" href="/contact/">{{ cabinets.hero.button }}</a>
    </div>
  </div>
  <div class="hero__media">
    <img src="{{ cabinets.hero.image }}" alt="{{ cabinets.hero.alt }}">
  </div>
</div>

{# Door-styles grid removed for now (data still in cabinets.json) — cabinet lines take its slot. #}
<div class="section">
  <div class="section-head">
    <h2>{{ cabinets.linesHeading }}</h2>
    <p class="lede lede--sm" style="max-width:44ch">{{ cabinets.linesLede }}</p>
  </div>
  <div class="grid grid--3 mfr-grid">
    {% for m in manufacturers %}
      <a class="mfr-card" href="{{ m.url }}" target="_blank" rel="noopener">
        <span class="mfr-card__logo"><img src="{{ m.logo }}" alt="{{ m.name }} logo" loading="lazy"></span>
        <span class="card__title">{{ m.name }}</span>
        <span class="card__meta">{{ m.desc }}</span>
        <span class="text-link">View catalog →</span>
      </a>
    {% endfor %}
  </div>
</div>

<div class="band" style="padding:64px var(--pad-x)">
  <span class="kicker kicker--light">How it works</span>
  <h2 style="margin:12px 0 40px">{{ cabinets.stepsHeading }}</h2>
  <div class="grid grid--3" style="gap:40px">
    {% for s in cabinets.steps %}
      <div class="step">
        <span class="step__num">{{ s.num }}</span>
        <h3>{{ s.title }}</h3>
        <p>{{ s.desc }}</p>
      </div>
    {% endfor %}
  </div>
</div>

{% set cta = cabinets.cta %}
{% include "partials/cross-cta.njk" %}

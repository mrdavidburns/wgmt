---
layout: layouts/base.njk
title: Recent Work — Kitchens & Baths
description: Recent countertop, cabinet, and tile installations around the Main Line.
permalink: /gallery/
schemaType: CollectionPage
---

<div class="page-head">
  <span class="kicker">{{ gallery.kicker }}</span>
  <h1>{{ gallery.heading }}</h1>
</div>

<div class="featured">
  <div class="photo photo--wide" style="aspect-ratio:auto;min-height:280px">
    <img src="{{ gallery.featured.image }}" alt="{{ gallery.featured.alt }}">
  </div>
  <div class="featured__copy">
    <span class="kicker" style="font-size:11px;letter-spacing:.2em">{{ gallery.featured.label }}</span>
    <h2 style="font-size:30px">{{ gallery.featured.heading }}</h2>
    <p class="lede lede--sm" style="font-size:14.5px">{{ gallery.featured.desc }}</p>
    <div class="featured__tags">
      <span>{{ gallery.featured.tags }}</span>
    </div>
  </div>
</div>

<div class="grid grid--3" style="padding:40px var(--pad-x) 56px">
  {% for p in projects %}
    <div class="card">
      <div class="photo photo--tall"><img src="{{ p.image }}" alt="{{ p.alt }}" loading="lazy"></div>
      <span class="card__title" style="font-size:17px">{{ p.title }}{% if p.location %} · {{ p.location }}{% endif %}</span>
    </div>
  {% endfor %}
</div>

{% set cta = gallery.cta %}
{% include "partials/cross-cta.njk" %}

---
layout: layouts/base.njk
title: Reviews & Testimonials
description: 100+ five-star reviews across Yelp, Google, and HomeAdvisor from kitchen and bath installations around the Main Line.
permalink: /reviews/
---

<div class="page-head">
  <span class="kicker">Testimonials</span>
  <h1>150+ reviews across the Main Line.</h1>
  <div class="review-sources">
    <a href="{{ site.links.google }}" target="_blank" rel="noopener">★ 4.9 &nbsp;Google (80+)</a>
    <a href="{{ site.links.yelp }}" target="_blank" rel="noopener">★ 5.0 &nbsp;Yelp (30+)</a>
    <a href="{{ site.links.homeadvisor }}" target="_blank" rel="noopener">★ 4.7 &nbsp;HomeAdvisor (50+)</a>
  </div>
</div>

{% set sourceUrls = { "Google": site.links.google, "Yelp": site.links.yelp, "HomeAdvisor": site.links.homeadvisor } %}
{% set featured = reviews | selectattr("featured") | first %}
<div class="review-featured">
  <p class="review-featured__quote">&ldquo;{{ featured.quote }}&rdquo;</p>
  <div class="review-featured__attr">{{ featured.author }}{% if featured.location %} · {{ featured.location }}{% endif %} · <a href="{{ sourceUrls[featured.source] }}" target="_blank" rel="noopener">{{ featured.source }}</a></div>
</div>

<div class="grid grid--3" style="padding:40px var(--pad-x) 56px">
  {% for r in reviews %}
    {% if not r.featured %}
      <div class="review-card">
        <span class="review-card__stars">★★★★★</span>
        <p class="review-card__quote">&ldquo;{{ r.quote }}&rdquo;</p>
        <span class="review-card__attr">{{ r.author }}{% if r.location %} · {{ r.location }}{% endif %} · <a href="{{ sourceUrls[r.source] }}" target="_blank" rel="noopener">{{ r.source }}</a></span>
      </div>
    {% endif %}
  {% endfor %}
</div>

{% set cta = { text: "Your review could be next.", button: "Get a Free Estimate" } %}
{% include "partials/cross-cta.njk" %}

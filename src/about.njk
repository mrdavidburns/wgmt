---
layout: layouts/base.njk
title: About Us
description: Family-owned since 2001. In-house fabrication, one accountable crew, and a lifetime installation warranty from our Ardmore showroom.
permalink: /about/
schemaType: AboutPage
---

<div class="hero hero--short">
  <div class="hero__copy" style="gap:22px">
    <span class="kicker">About Us</span>
    <h1>{{ about.hero.heading }}</h1>
    <p class="lede" style="font-size:16px;max-width:46ch">{{ about.hero.lede1 }}</p>
    <p class="lede" style="font-size:16px;max-width:46ch">{{ about.hero.lede2 }}</p>
  </div>
  <div class="hero__media">
    <img src="{{ about.hero.image }}" alt="{{ about.hero.alt }}">
  </div>
</div>

<div class="stats">
  {% for s in about.stats %}
    <div class="stats__cell">
      <span class="stats__num">{{ s.num }}</span>
      <span class="stats__label">{{ s.label }}</span>
    </div>
  {% endfor %}
</div>

<div class="section">
  <h2 style="margin-bottom:36px">{{ about.valuesHeading }}</h2>
  <div class="grid grid--3" style="gap:40px">
    {% for v in about.values %}
      <div class="value">
        <h3>{{ v.title }}</h3>
        <p>{{ v.desc }}</p>
      </div>
    {% endfor %}
  </div>
</div>

{% set cta = about.cta %}
{% include "partials/cross-cta.njk" %}
